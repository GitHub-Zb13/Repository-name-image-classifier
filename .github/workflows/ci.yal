name: Run Image Classifier

on:
  push:

jobs:
  test:
    runs-on: ubuntu-latest

    steps:
      - name: 拉代码
        uses: actions/checkout@v3

      - name: 安装Python
        uses: actions/setup-python@v4
        with:
          python-version: "3.10"

      - name: 运行脚本
        run: |
          python classify_with_time_range.py \
            --src test_data \
            --dst output
